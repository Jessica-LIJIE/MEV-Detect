# 复制本文件为 .env 并填入你的密钥（.env 不要提交到 Git）

# Ethereum Mainnet
ETH_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Arbitrum One
ARB_HTTP_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# 若 Infura 开启了「Require API Key Secret」，必填此项
INFURA_API_KEY_SECRET=

# 可选
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=

# cpu 或 cuda（RTX 50 系列暂建议用 cpu）
DEVICE=cpu
